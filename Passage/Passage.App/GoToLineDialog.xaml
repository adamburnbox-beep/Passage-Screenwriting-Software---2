<Window x:Class="Passage.App.GoToLineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Go To Line"
        Width="300"
        Height="150"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
  <Border Padding="16" Background="{DynamicResource WindowBackground}">
    <StackPanel>
      <TextBlock Text="Line number:"
                 Foreground="{DynamicResource SecondaryText}"
                 Margin="0,0,0,8" />
      <TextBox x:Name="LineTextBox"
               Height="28"
               VerticalContentAlignment="Center"
               PreviewKeyDown="LineTextBox_PreviewKeyDown" />
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,16,0,0">
        <Button Content="Go"
                Width="80"
                Margin="0,0,8,0"
                IsDefault="True"
                Click="Go_Click" />
        <Button Content="Cancel"
                Width="80"
                IsCancel="True"
                Click="Cancel_Click" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
