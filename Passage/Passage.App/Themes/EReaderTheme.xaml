<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFF2F2F2" />
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FF000000" />

  <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFF5F5F5" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FF000000" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FFA0A0A0" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#FF606060" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FFF8F8F8" />
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FFFFFFFF" />

  <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FF000000" />
  <SolidColorBrush x:Key="{x:Static SystemColors.InfoBrushKey}" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="{x:Static SystemColors.InfoTextBrushKey}" Color="#FF000000" />

  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFD0D0D0" />
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF000000" />
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FFE0E0E0" />
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FF000000" />

  <SolidColorBrush x:Key="WindowBackground" Color="#FFF2F2F2" />
  <SolidColorBrush x:Key="WindowForeground" Color="#FF000000" />

  <SolidColorBrush x:Key="SurfaceBackground" Color="#FFF5F5F5" />
  <SolidColorBrush x:Key="SurfaceMutedBackground" Color="#FFE0E0E0" />
  <SolidColorBrush x:Key="SurfaceRaisedBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="SurfaceBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="SurfaceMutedBorder" Color="#FFA0A0A0" />

  <SolidColorBrush x:Key="CardBaseBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="CardAlternatingBackground" Color="#FFE0E0E0" />

  <SolidColorBrush x:Key="ControlBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="ControlForeground" Color="#FF000000" />
  <SolidColorBrush x:Key="ControlBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="ControlAccent" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardDividerBrush" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardActDividerBrush" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardLaneGuideBrush" Color="#1A000000" />
  <SolidColorBrush x:Key="BeatBoardActBoundaryBrush" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardSequenceSeparatorBrush" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardLaneSeparator" Color="#80000000" />
  <SolidColorBrush x:Key="BeatBoardActLaneBackground" Color="#05000000" />
  <SolidColorBrush x:Key="BeatBoardSequenceLaneBackground" Color="#0A000000" />

  <SolidColorBrush x:Key="HeaderText" Color="#FF000000" />
  <SolidColorBrush x:Key="SecondaryText" Color="#FF404040" />
  <SolidColorBrush x:Key="MutedText" Color="#FF606060" />
  <SolidColorBrush x:Key="SubtleText" Color="#FF808080" />

  <SolidColorBrush x:Key="OutlineSectionBackground" Color="#FFE0E0E0" />
  <SolidColorBrush x:Key="OutlineSectionBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="OutlineSynopsisBackground" Color="#FFF8F8F8" />
  <SolidColorBrush x:Key="OutlineSynopsisBorder" Color="#FF808080" />
  <SolidColorBrush x:Key="OutlineNoteBackground" Color="#FFF0F0F0" />
  <SolidColorBrush x:Key="OutlineNoteBorder" Color="#FF606060" />
  <SolidColorBrush x:Key="OutlineSceneBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="OutlineCardBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardActCardBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="BeatBoardOutlineActCardBackground" Color="#15000000" />
  <SolidColorBrush x:Key="BeatBoardOutlineActCardCollapsedBackground" Color="#10000000" />
  <SolidColorBrush x:Key="BeatBoardSequenceCardBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="BeatBoardOutlineSequenceCardBackground" Color="#10000000" />
  <SolidColorBrush x:Key="BeatBoardSceneCardBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="BeatBoardSceneCardBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardSceneCardAccentForeground" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardOutlineSceneCardBackground" Color="#0D000000" />
  <SolidColorBrush x:Key="BeatBoardNoteCardBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="BeatBoardNoteCardBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardNoteCardAccentForeground" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardNoteCardContentForeground" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardOutlineNoteCardBackground" Color="#0D000000" />
  <SolidColorBrush x:Key="BeatBoardDefaultCardBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="BeatBoardDefaultCardBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardOutlineDefaultCardBackground" Color="#08000000" />
  <SolidColorBrush x:Key="BeatBoardOutlineDefaultCardBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardDefaultCardAccentForeground" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardGhostLayerBackground" Color="#FFE0E0E0" />
  <SolidColorBrush x:Key="BeatBoardGhostCardBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="BeatBoardGhostTitleForeground" Color="#FF000000" />
  <SolidColorBrush x:Key="BeatBoardGhostDescriptionForeground" Color="#FF404040" />

  <SolidColorBrush x:Key="EditorPageBackground" Color="#FFFDFDFD" />
  <SolidColorBrush x:Key="EditorPageBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="EditorPageShadow" Color="#11000000" />
  <SolidColorBrush x:Key="EditorForeground" Color="#FF000000" />
  <SolidColorBrush x:Key="EditorSelection" Color="#FFD0D0D0" />
  <SolidColorBrush x:Key="EditorCaret" Color="#FF000000" />

  <SolidColorBrush x:Key="GoalSuccessBackground" Color="#FFF0F0F0" />
  <SolidColorBrush x:Key="GoalSuccessBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="GoalSuccessForeground" Color="#FF000000" />
  <SolidColorBrush x:Key="GoalValueText" Color="#FF000000" />
  <SolidColorBrush x:Key="GoalLabelText" Color="#FF404040" />
  <SolidColorBrush x:Key="GoalOverallBackground" Color="#FFFFFFFF" />
  <SolidColorBrush x:Key="GoalOverallBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="DestructiveBackground" Color="#FFD0D0D0" />
  <SolidColorBrush x:Key="DestructiveBorder" Color="#FF000000" />
  <SolidColorBrush x:Key="DestructiveForeground" Color="#FF000000" />

  <Style TargetType="ToolTip">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource HeaderText}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="HasDropShadow" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToolTip">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
