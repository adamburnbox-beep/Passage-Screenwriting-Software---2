<UserControl x:Class="Passage.App.Views.GoalPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Passage.App.Converters"
             x:Name="GoalRoot">
  <UserControl.Resources>
    <converters:GoalTypeLabelConverter x:Key="GoalTypeLabelConverter" />
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Style x:Key="GoalTypeComboBoxStyle" TargetType="ComboBox">
      <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="MinWidth" Value="160" />
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid SnapsToDevicePixels="True">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
              </Grid.ColumnDefinitions>

              <ToggleButton x:Name="DropDownToggle"
                            Grid.ColumnSpan="2"
                            Focusable="False"
                            ClickMode="Press"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                            Background="Transparent"
                            BorderThickness="0"
                            OverridesDefaultStyle="True">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="Transparent" />
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>

              <Border x:Name="ComboBorder"
                      Grid.ColumnSpan="2"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="2"
                      SnapsToDevicePixels="True"
                      IsHitTestVisible="False" />

              <ContentPresenter x:Name="ContentSite"
                                Grid.Column="0"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                IsHitTestVisible="False"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />

              <Border Grid.Column="1"
                      Background="{DynamicResource SurfaceMutedBackground}"
                      BorderBrush="{DynamicResource ControlBorder}"
                      BorderThickness="1,0,0,0"
                      CornerRadius="0,2,2,0"
                      IsHitTestVisible="False">
                <Path Data="M 0 0 L 5 5 L 10 0 Z"
                      Fill="{DynamicResource ControlForeground}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
              </Border>

              <Popup x:Name="PART_Popup"
                     AllowsTransparency="True"
                     Focusable="False"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     Placement="Bottom"
                     PlacementTarget="{Binding ElementName=DropDownToggle}"
                     PopupAnimation="Fade"
                     StaysOpen="False">
                <Border Background="{DynamicResource SurfaceBackground}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1"
                        Margin="0,2,0,0"
                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                  <ScrollViewer CanContentScroll="True"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
              </Trigger>
              <Trigger Property="IsDropDownOpen" Value="True">
                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Border Padding="14,12"
          CornerRadius="10"
          Background="{DynamicResource SurfaceBackground}"
          BorderBrush="{DynamicResource SurfaceBorder}"
          BorderThickness="1"
          MinHeight="360">
    <StackPanel>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="Goal"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource HeaderText}" />
        </StackPanel>
      </Grid>

      <TabControl Margin="0,12,0,0"
                  Background="Transparent"
                  BorderThickness="0"
                  SelectedIndex="0">
        <TabItem Header="Session">
          <Border Padding="12"
                  CornerRadius="10"
                  Background="{DynamicResource GoalSuccessBackground}"
                  BorderBrush="{DynamicResource GoalSuccessBorder}"
                  BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.ColumnSpan="2">
            <TextBlock Text="Session"
                       FontSize="12.5"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource GoalSuccessForeground}" />
          </StackPanel>

          <StackPanel Grid.Row="1"
                      Grid.ColumnSpan="2"
                      Margin="0,10,0,0">
            <TextBlock Text="Type"
                       Foreground="{DynamicResource SecondaryText}"
                       FontSize="11"
                       FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding SessionGoalTypes}"
                      SelectedItem="{Binding SessionSelectedGoalType, Mode=TwoWay}"
                      Margin="0,4,0,0"
                      Padding="8,5"
                      Background="{DynamicResource ControlBackground}"
                      BorderBrush="{DynamicResource ControlBorder}"
                      Foreground="{DynamicResource GoalValueText}"
                      FontSize="12.5"
                      Style="{StaticResource GoalTypeComboBoxStyle}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource GoalTypeLabelConverter}}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <Grid Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="96" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="Target"
                         Foreground="{DynamicResource SecondaryText}"
                         FontSize="11"
                         FontWeight="SemiBold" />
              <TextBox Text="{Binding SessionGoalTargetValue, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                       PreviewTextInput="GoalTargetValue_PreviewTextInput"
                       DataObject.Pasting="GoalTargetValue_Pasting"
                       Margin="0,4,0,0"
                       Padding="8,5"
                       Background="{DynamicResource ControlBackground}"
                       BorderBrush="{DynamicResource ControlBorder}"
                       Foreground="{DynamicResource GoalValueText}"
                       FontSize="12.5" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="10,0,0,0">
              <TextBlock Text="{Binding SessionGoalTargetUnitLabel}"
                         Foreground="{DynamicResource GoalLabelText}"
                         FontSize="11"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding SessionGoalProgressPercent, StringFormat={}{0:0}%}"
                         Margin="0,4,0,0"
                         Foreground="{DynamicResource GoalValueText}"
                         FontSize="13"
                         FontWeight="SemiBold" />
            </StackPanel>
          </Grid>

          <ProgressBar Grid.Row="3"
                       Grid.ColumnSpan="2"
                       Height="10"
                       Margin="0,10,0,0"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding SessionGoalProgressPercent, Mode=OneWay}" />

          <Grid Grid.Row="4"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="Current"
                         Foreground="{DynamicResource SecondaryText}"
                         FontSize="10.5"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding SessionGoalCurrentDisplayText}"
                         Foreground="{DynamicResource GoalValueText}"
                         FontSize="12.5"
                         Margin="0,2,0,0"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1">
              <TextBlock Text="Target"
                         Foreground="{DynamicResource SecondaryText}"
                         FontSize="10.5"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding SessionGoalTargetDisplayText}"
                         Foreground="{DynamicResource GoalValueText}"
                         FontSize="12.5"
                         Margin="0,2,0,0"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="2">
              <TextBlock Text="State"
                         Foreground="{DynamicResource SecondaryText}"
                         FontSize="10.5"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding SessionGoalStateText}"
                         Foreground="{DynamicResource GoalValueText}"
                         FontSize="12.5"
                         Margin="0,2,0,0"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>

          <StackPanel Grid.Row="5"
                      Grid.ColumnSpan="2"
                      Margin="0,10,0,0">
            <Button Content="Reset Session Goal"
                    Click="GoalResetSession_Click"
                    Padding="10,4"
                    MinWidth="148"
                    HorizontalAlignment="Left" />

            <StackPanel Margin="0,10,0,0"
                        Visibility="{Binding IsTimerGoal, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Text="Timer"
                         Foreground="{DynamicResource SecondaryText}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Margin="0,0,0,6" />

              <WrapPanel>
                <Button Content="{Binding GoalTimerPrimaryButtonText}"
                        Click="GoalPrimaryTimerButton_Click"
                        Margin="0,0,6,0"
                        Padding="10,4"
                        MinWidth="76" />
                <Button Content="{Binding GoalTimerSecondaryButtonText}"
                        Click="GoalSecondaryTimerButton_Click"
                        Margin="0,0,6,0"
                        Padding="10,4"
                        MinWidth="76" />
              </WrapPanel>

              <StackPanel Orientation="Horizontal"
                          Margin="0,8,0,0">
                <TextBlock Text="Elapsed "
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="11.5"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding GoalTimerElapsedText}"
                           Foreground="{DynamicResource WindowForeground}"
                           FontSize="11.5"
                           Margin="0,0,18,0" />
                <TextBlock Text="Remaining "
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="11.5"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding GoalTimerRemainingText}"
                           Foreground="{DynamicResource WindowForeground}"
                           FontSize="11.5" />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Grid>
          </Border>
        </TabItem>

        <TabItem Header="Overall">
          <Border Padding="12"
                  CornerRadius="10"
                  Background="{DynamicResource GoalOverallBackground}"
                  BorderBrush="{DynamicResource GoalOverallBorder}"
                  BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.ColumnSpan="2">
            <TextBlock Text="Overall"
                       FontSize="12.5"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource HeaderText}" />
            <TextBlock Text="Counts the full document total across sessions."
                       FontSize="11"
                       Foreground="{DynamicResource MutedText}"
                       Margin="0,2,0,0"
                       TextWrapping="Wrap" />
          </StackPanel>

          <StackPanel Grid.Row="1"
                      Grid.ColumnSpan="2"
                      Margin="0,10,0,0">
            <TextBlock Text="Type"
                       Foreground="{DynamicResource GoalLabelText}"
                       FontSize="11"
                       FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding GoalTypes}"
                      SelectedItem="{Binding SelectedGoalType, Mode=TwoWay}"
                      Margin="0,4,0,0"
                      Padding="8,5"
                      Background="{DynamicResource ControlBackground}"
                      BorderBrush="{DynamicResource ControlBorder}"
                      Foreground="{DynamicResource WindowForeground}"
                      FontSize="12.5"
                      Style="{StaticResource GoalTypeComboBoxStyle}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource GoalTypeLabelConverter}}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <Grid Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="96" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="Target"
                         Foreground="{DynamicResource GoalLabelText}"
                         FontSize="11"
                         FontWeight="SemiBold" />
              <TextBox Text="{Binding GoalTargetValue, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                       PreviewTextInput="GoalTargetValue_PreviewTextInput"
                       DataObject.Pasting="GoalTargetValue_Pasting"
                       Margin="0,4,0,0"
                       Padding="8,5"
                       Background="{DynamicResource ControlBackground}"
                       BorderBrush="{DynamicResource ControlBorder}"
                       Foreground="{DynamicResource WindowForeground}"
                       FontSize="12.5" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="10,0,0,0">
              <TextBlock Text="{Binding GoalTargetUnitLabel}"
                         Foreground="{DynamicResource SecondaryText}"
                         FontSize="11"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding GoalProgressPercent, StringFormat={}{0:0}%}"
                         Margin="0,4,0,0"
                         Foreground="{DynamicResource WindowForeground}"
                         FontSize="13"
                         FontWeight="SemiBold" />
            </StackPanel>
          </Grid>

          <ProgressBar Grid.Row="3"
                       Grid.ColumnSpan="2"
                       Height="10"
                       Margin="0,10,0,0"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding GoalProgressPercent, Mode=OneWay}" />

          <Grid Grid.Row="4"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="Current"
                         Foreground="{DynamicResource GoalLabelText}"
                         FontSize="10.5"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding GoalCurrentDisplayText}"
                         Foreground="{DynamicResource WindowForeground}"
                         FontSize="12.5"
                         Margin="0,2,0,0"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1">
              <TextBlock Text="Target"
                         Foreground="{DynamicResource GoalLabelText}"
                         FontSize="10.5"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding GoalTargetDisplayText}"
                         Foreground="{DynamicResource WindowForeground}"
                         FontSize="12.5"
                         Margin="0,2,0,0"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="2">
              <TextBlock Text="State"
                         Foreground="{DynamicResource GoalLabelText}"
                         FontSize="10.5"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding GoalStateText}"
                         Foreground="{DynamicResource WindowForeground}"
                         FontSize="12.5"
                         Margin="0,2,0,0"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>

        </Grid>
          </Border>
        </TabItem>
      </TabControl>
    </StackPanel>
  </Border>
</UserControl>
