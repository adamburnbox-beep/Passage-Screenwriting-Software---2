<Window x:Class="Passage.App.Views.TitlePageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:Passage.App.Views"
        xmlns:conv="clr-namespace:Passage.App.Converters"
        mc:Ignorable="d"
        Title="Title Page" Height="700" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource WindowForeground}"
        ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibility" />
        <conv:UppercaseConverter x:Key="UppercaseConverter" />
        

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="{DynamicResource ControlAccent}" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Side: Inputs -->
        <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0" PreviewMouseWheel="FieldsScrollViewer_PreviewMouseWheel">
            <StackPanel x:Name="FieldsPanel">
                <TextBlock Text="Title" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBoxStyle}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" FontSize="16" FontWeight="Bold" FontFamily="Courier Prime, Courier" />

                <TextBlock Text="Episode" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Episode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBoxStyle}" />

                <TextBlock Text="Credit" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Credit, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBoxStyle}" />

                <TextBlock Text="Author" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBoxStyle}" />

                <TextBlock Text="Source" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Source, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBoxStyle}" />

                <TextBlock Text="Contact" Style="{StaticResource FieldLabelStyle}" />
                <Grid>
                    <TextBox Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBoxStyle}" Height="100" TextWrapping="Wrap" AcceptsReturn="True" />
                    <TextBlock IsHitTestVisible="False" Foreground="{DynamicResource SecondaryText}" Margin="10,8,0,0" Opacity="0.5" Visibility="{Binding Contact, Converter={StaticResource StringToVisibility}, ConverterParameter=Inverse}">
                        <Run Text="Your Name or Agent's Name" /><LineBreak/>
                        <Run Text="Your Street Address" /><LineBreak/>
                        <Run Text="Your City, State" /><LineBreak/>
                        <Run Text="Phone No." />
                    </TextBlock>
                </Grid>

                <TextBlock Text="Draft date" Style="{StaticResource FieldLabelStyle}" />
                <Grid>
                    <TextBox Text="{Binding DraftDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBoxStyle}" Padding="8,5,50,5" />
                    <TextBlock Text="Today" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="{DynamicResource SecondaryText}" FontSize="11" IsHitTestVisible="False" />
                </Grid>

                <TextBlock Text="Revision" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Revision, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBoxStyle}" />

                <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBoxStyle}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" />
            </StackPanel>
        </ScrollViewer>

        <!-- Right Side: Preview -->
        <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource SurfaceRaisedBackground}" BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1" CornerRadius="4">
            <Viewbox Margin="20">
                <Border Width="850" Height="1100" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource SurfaceBorder}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Color="Black" ShadowDepth="2" Opacity="0.3" />
                    </Border.Effect>
                    <Grid Margin="100,72,72,72">
                        <!-- Main Content Centered Vertically -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title, Converter={StaticResource UppercaseConverter}}" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"
                                       FontSize="28" 
                                       FontWeight="Bold" 
                                       FontFamily="Courier Prime, Courier" />
                            
                            <TextBlock Text="{Binding Episode}" HorizontalAlignment="Center" FontFamily="Courier Prime, Courier" FontSize="18" Visibility="{Binding Episode, Converter={StaticResource StringToVisibility}}" Margin="0,12,0,0" />
                            
                            <Border Height="80" /> <!-- Spacer between Title/Episode and Author info -->
                            
                            <TextBlock Text="{Binding Credit}" HorizontalAlignment="Center" FontFamily="Courier Prime, Courier" FontSize="18" Visibility="{Binding Credit, Converter={StaticResource StringToVisibility}}" />
                            <TextBlock Text="{Binding Author}" HorizontalAlignment="Center" FontFamily="Courier Prime, Courier" FontSize="18" Visibility="{Binding Author, Converter={StaticResource StringToVisibility}}" Margin="0,8,0,0"/>
                            
                            <TextBlock Text="{Binding Source}" HorizontalAlignment="Center" FontFamily="Courier Prime, Courier" FontSize="18" Visibility="{Binding Source, Converter={StaticResource StringToVisibility}}" Margin="0,24,0,0" />
                        </StackPanel>
                        
                        <!-- Bottom Info -->
                        <Grid VerticalAlignment="Bottom">
                            <StackPanel HorizontalAlignment="Left" MaxWidth="400">
                                <TextBlock Text="{Binding Revision}" FontFamily="Courier Prime, Courier" FontSize="18" Visibility="{Binding Revision, Converter={StaticResource StringToVisibility}}" />
                                <TextBlock Text="{Binding DraftDate}" FontFamily="Courier Prime, Courier" FontSize="18" Visibility="{Binding DraftDate, Converter={StaticResource StringToVisibility}}" />
                                <TextBlock Text="{Binding Contact}" FontFamily="Courier Prime, Courier" FontSize="18" Visibility="{Binding Contact, Converter={StaticResource StringToVisibility}}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Notes}" FontFamily="Courier Prime, Courier" FontSize="18" Visibility="{Binding Notes, Converter={StaticResource StringToVisibility}}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Viewbox>
        </Border>

        <!-- Bottom Row: Buttons -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <Button Content="Delete Page" HorizontalAlignment="Left" Foreground="White" Background="#d0021b" BorderThickness="0" Padding="15,6" x:Name="DeleteButton" Click="DeleteButton_Click" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelButton_Click" Style="{StaticResource DarkChromeButtonStyle}" Padding="15,6" Margin="0,0,10,0" x:Name="CancelButton" />
                <Button Content="Update Page" Click="OkButton_Click" Style="{StaticResource DarkChromeButtonStyle}" BorderBrush="{DynamicResource ControlAccent}" Padding="15,6" FontWeight="Bold" x:Name="UpdateButton" IsDefault="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
