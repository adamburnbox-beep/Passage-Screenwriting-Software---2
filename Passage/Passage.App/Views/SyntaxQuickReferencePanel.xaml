<UserControl x:Class="Passage.App.Views.SyntaxQuickReferencePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <SolidColorBrush x:Key="ReferencePanelBackgroundBrush" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="ReferenceCardBackgroundBrush" Color="#FF252526" />
    <SolidColorBrush x:Key="ReferenceBorderBrush" Color="#FF333337" />
    <SolidColorBrush x:Key="ReferenceHeaderBrush" Color="#FFF4F4F4" />
    <SolidColorBrush x:Key="ReferenceBodyBrush" Color="#FFD0D0D0" />
    <SolidColorBrush x:Key="ReferenceMutedBrush" Color="#FF9B9B9B" />
    <SolidColorBrush x:Key="SyntaxBlueBrush" Color="#FF569CD6" />
    <SolidColorBrush x:Key="SyntaxOrangeBrush" Color="#FFCE9178" />
    <SolidColorBrush x:Key="SyntaxGreenBrush" Color="#FF4EC9B0" />
    <SolidColorBrush x:Key="CopyButtonBackgroundBrush" Color="#FF2D2D30" />
    <SolidColorBrush x:Key="CopyButtonBorderBrush" Color="#FF3E3E42" />
    <SolidColorBrush x:Key="CopyButtonHoverBrush" Color="#FF38383D" />

    <Style x:Key="RuleCardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource ReferenceCardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ReferenceBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="RuleTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource ReferenceHeaderBrush}" />
    </Style>

    <Style x:Key="RuleBodyStyle" TargetType="TextBlock">
      <Setter Property="Margin" Value="0,6,0,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource ReferenceBodyBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ExampleLabelStyle" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource ReferenceBodyBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <Style x:Key="SyntaxChipStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource ReferencePanelBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ReferenceBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Margin" Value="0,0,12,0" />
      <Setter Property="MinWidth" Value="84" />
    </Style>

    <Style x:Key="SyntaxTextStyle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Consolas, Courier New" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CopyIconButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="{StaticResource CopyButtonBackgroundBrush}" />
      <Setter Property="Foreground" Value="{StaticResource ReferenceHeaderBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource CopyButtonBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource CopyButtonHoverBrush}" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource SyntaxBlueBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Border Background="{StaticResource ReferencePanelBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="18,16">
        <TextBlock Text="Syntax Quick Reference"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource ReferenceHeaderBrush}" />
        <TextBlock Text="Keep Fountain structure markers close while writing."
                   Margin="0,6,0,16"
                   FontSize="12"
                   Foreground="{StaticResource ReferenceMutedBrush}"
                   TextWrapping="Wrap" />

        <Border Style="{StaticResource RuleCardStyle}">
          <StackPanel>
            <TextBlock Text="Sections"
                       Style="{StaticResource RuleTitleStyle}" />
            <TextBlock Text="Use section markers to organize Acts, Sequences, and Scenes. These markers are for structure only and do not print in the screenplay output."
                       Style="{StaticResource RuleBodyStyle}" />

            <StackPanel Margin="0,14,0,0">
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SyntaxChipStyle}">
                  <TextBlock Text="#"
                             Style="{StaticResource SyntaxTextStyle}"
                             Foreground="{StaticResource SyntaxBlueBrush}" />
                </Border>

                <TextBlock Grid.Column="1"
                           Text="Act heading"
                           Style="{StaticResource ExampleLabelStyle}" />

                <Button Grid.Column="2"
                        Tag="#"
                        ToolTip="Copy #"
                        Style="{StaticResource CopyIconButtonStyle}"
                        Click="CopySyntax_Click">
                  <TextBlock FontFamily="Segoe MDL2 Assets"
                             FontSize="14"
                             Text="&#xE8C8;" />
                </Button>
              </Grid>

              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SyntaxChipStyle}">
                  <TextBlock Text="##"
                             Style="{StaticResource SyntaxTextStyle}"
                             Foreground="{StaticResource SyntaxBlueBrush}" />
                </Border>

                <TextBlock Grid.Column="1"
                           Text="Sequence heading"
                           Style="{StaticResource ExampleLabelStyle}" />

                <Button Grid.Column="2"
                        Tag="##"
                        ToolTip="Copy ##"
                        Style="{StaticResource CopyIconButtonStyle}"
                        Click="CopySyntax_Click">
                  <TextBlock FontFamily="Segoe MDL2 Assets"
                             FontSize="14"
                             Text="&#xE8C8;" />
                </Button>
              </Grid>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SyntaxChipStyle}">
                  <TextBlock Text="###"
                             Style="{StaticResource SyntaxTextStyle}"
                             Foreground="{StaticResource SyntaxBlueBrush}" />
                </Border>

                <TextBlock Grid.Column="1"
                           Text="Scene grouping marker"
                           Style="{StaticResource ExampleLabelStyle}" />

                <Button Grid.Column="2"
                        Tag="###"
                        ToolTip="Copy ###"
                        Style="{StaticResource CopyIconButtonStyle}"
                        Click="CopySyntax_Click">
                  <TextBlock FontFamily="Segoe MDL2 Assets"
                             FontSize="14"
                             Text="&#xE8C8;" />
                </Button>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource RuleCardStyle}">
          <StackPanel>
            <TextBlock Text="Synopses"
                       Style="{StaticResource RuleTitleStyle}" />
            <TextBlock Text="Use a synopsis line to add a short summary beneath the current section or scene."
                       Style="{StaticResource RuleBodyStyle}" />

            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Border Style="{StaticResource SyntaxChipStyle}">
                <TextBlock Text="="
                           Style="{StaticResource SyntaxTextStyle}"
                           Foreground="{StaticResource SyntaxOrangeBrush}" />
              </Border>

              <TextBlock Grid.Column="1"
                         Text="Summary for the section or scene below it."
                         Style="{StaticResource ExampleLabelStyle}" />

              <Button Grid.Column="2"
                      Tag="="
                      ToolTip="Copy ="
                      Style="{StaticResource CopyIconButtonStyle}"
                      Click="CopySyntax_Click">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Text="&#xE8C8;" />
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource RuleCardStyle}"
                Margin="0">
          <StackPanel>
            <TextBlock Text="Notes"
                       Style="{StaticResource RuleTitleStyle}" />
            <TextBlock Text="Use Fountain notes for private comments, reminders, or production details that should stay internal."
                       Style="{StaticResource RuleBodyStyle}" />

            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Border Style="{StaticResource SyntaxChipStyle}"
                      MinWidth="120">
                <TextBlock Text="[[ Your Note ]]"
                           Style="{StaticResource SyntaxTextStyle}"
                           Foreground="{StaticResource SyntaxGreenBrush}" />
              </Border>

              <TextBlock Grid.Column="1"
                         Text="Internal comment that stays out of the printed script."
                         Style="{StaticResource ExampleLabelStyle}" />

              <Button Grid.Column="2"
                      Tag="[[ Your Note ]]"
                      ToolTip="Copy [[ Your Note ]]"
                      Style="{StaticResource CopyIconButtonStyle}"
                      Click="CopySyntax_Click">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Text="&#xE8C8;" />
              </Button>
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
