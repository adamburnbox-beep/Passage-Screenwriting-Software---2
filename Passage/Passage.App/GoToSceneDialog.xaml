<Window x:Class="Passage.App.GoToSceneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Go To Scene"
        Width="420"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">
  <Border Padding="16" Background="{DynamicResource WindowBackground}">
    <DockPanel LastChildFill="True">
      <TextBlock DockPanel.Dock="Top"
                 Text="Select a scene heading"
                 Foreground="{DynamicResource SecondaryText}"
                 FontWeight="SemiBold"
                 Margin="0,0,0,10" />

      <ListBox x:Name="SceneListBox"
               DisplayMemberPath="DisplayText"
               PreviewKeyDown="SceneListBox_PreviewKeyDown"
               MouseDoubleClick="SceneListBox_MouseDoubleClick"
               MinHeight="300" />

      <StackPanel DockPanel.Dock="Bottom"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,12,0,0">
        <Button Content="Jump"
                Width="80"
                Margin="0,0,8,0"
                IsDefault="True"
                Click="Jump_Click" />
        <Button Content="Close"
                Width="80"
                IsCancel="True"
                Click="Close_Click" />
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
