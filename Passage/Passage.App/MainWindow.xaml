                       Text="{Binding BoardDescription}">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource BeatBoardOutlineDescriptionStyle}">
                  <Setter Property="Foreground" Value="{DynamicResource BeatBoardNoteCardContentForeground}" />
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBox x:Name="InlineDescriptionTextBox"
                     Style="{StaticResource BeatBoardInlineDescriptionTextBoxStyle}"
                     Margin="0,6,0,0" />
          </StackPanel>

          <Button Grid.Column="1"
                  Command="{Binding DataContext.SelectedDocument.ToggleBoardElementCollapsedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  Style="{StaticResource BeatBoardCollapseChevronButtonStyle}"
                  Foreground="{DynamicResource SecondaryText}"
                  Margin="12,0,0,0"
                  VerticalAlignment="Top" />
        </Grid>
      </Border>
      <DataTemplate.Triggers>
        <DataTrigger Binding="{Binding Path=(app:MainWindow.IsEditing), RelativeSource={RelativeSource Self}}" Value="True">
          <Setter TargetName="HeadingTextBlock" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="HeadingPlaceholder" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="InlineHeadingTextBox" Property="Visibility" Value="Visible" />
          <Setter TargetName="DescriptionTextBlock" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="InlineDescriptionTextBox" Property="Visibility" Value="Visible" />
          <Setter TargetName="EditIconPath" Property="Style" Value="{StaticResource BeatBoardCommitCheckIconStyle}" />
          <Setter TargetName="EditButton" Property="ToolTip" Value="Save changes" />
        </DataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding Path=(app:MainWindow.IsEditing), RelativeSource={RelativeSource Self}}" Value="False" />
            <Condition Binding="{Binding Heading}" Value="" />
          </MultiDataTrigger.Conditions>
          <Setter TargetName="HeadingTextBlock" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="HeadingPlaceholder" Property="Visibility" Value="Visible" />
        </MultiDataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding Path=(app:MainWindow.IsEditing), RelativeSource={RelativeSource Self}}" Value="False" />
            <Condition Binding="{Binding Heading}" Value="{x:Null}" />
          </MultiDataTrigger.Conditions>
          <Setter TargetName="HeadingTextBlock" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="HeadingPlaceholder" Property="Visibility" Value="Visible" />
        </MultiDataTrigger>
      </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate x:Key="BeatBoardOutlineDefaultCardTemplate">
      <Border Style="{StaticResource BeatBoardOutlineDefaultCardBorderStyle}"
              Cursor="Hand"
              MouseLeftButtonDown="BeatBoardCard_MouseLeftButtonDown"
              MouseLeftButtonUp="BeatBoardCard_MouseLeftButtonUp">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
              <StackPanel Style="{StaticResource BeatBoardOutlineTypeSelectorHostStyle}"
                          PreviewMouseLeftButtonDown="BeatBoardTypeSelector_PreviewMouseLeftButtonDown"
                          Margin="0">
                <StackPanel.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Act" Tag="Act" Click="BeatBoardTypeMenuItem_Click" />
                    <MenuItem Header="Sequence" Tag="Sequence" Click="BeatBoardTypeMenuItem_Click" />
                    <MenuItem Header="Scene" Tag="Scene" Click="BeatBoardTypeMenuItem_Click" />
                    <MenuItem Header="Note" Tag="Note" Click="BeatBoardTypeMenuItem_Click" />
                  </ContextMenu>
                </StackPanel.ContextMenu>
                <Path Style="{StaticResource BeatBoardTypeSelectorTriangleStyle}"
                      Fill="{DynamicResource BeatBoardDefaultCardAccentForeground}" />
                <TextBlock Text="{Binding KindLabel, Converter={StaticResource UppercaseConverter}}"
                           Style="{StaticResource BeatBoardOutlineTypeSelectorStyle}"
                           Foreground="{DynamicResource BeatBoardDefaultCardAccentForeground}" />
              </StackPanel>
              <Button x:Name="EditButton"
                      Click="BeatBoardEditButton_Click"
                      Style="{StaticResource BeatBoardBoardEditButtonStyle}"
                      Foreground="{DynamicResource BeatBoardDefaultCardAccentForeground}"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      ToolTip="Edit card">
                <Path x:Name="EditIconPath" Style="{StaticResource BeatBoardCompactPencilIconStyle}" />
              </Button>
            </StackPanel>
            <Grid>
              <TextBlock x:Name="HeadingTextBlock"
                         Text="{Binding Heading}"
                         Style="{StaticResource BeatBoardOutlineHeadingStyle}" />
              <TextBlock x:Name="HeadingPlaceholder"
                         Text="NEW HEADING"
                         Style="{StaticResource BeatBoardOutlineHeadingStyle}"
                         Opacity="0.4"
                         FontStyle="Italic"
                         Visibility="Collapsed" />
            </Grid>
            <TextBox x:Name="InlineHeadingTextBox"
                     Style="{StaticResource BeatBoardInlineTextBoxStyle}"
                     Tag="NEW HEADING" />
            <TextBlock x:Name="DescriptionTextBlock"
                       Text="{Binding BoardDescription}">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource BeatBoardOutlineDescriptionStyle}">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBox x:Name="InlineDescriptionTextBox"
                     Style="{StaticResource BeatBoardInlineDescriptionTextBoxStyle}"
                     Margin="0,6,0,0" />
          </StackPanel>

          <Button Grid.Column="1"
                  Command="{Binding DataContext.SelectedDocument.ToggleBoardElementCollapsedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  CommandParameter="{Binding}"
                  Style="{StaticResource BeatBoardCollapseChevronButtonStyle}"
                  Foreground="{DynamicResource BeatBoardDefaultCardAccentForeground}"
                  Margin="12,0,0,0"
                  VerticalAlignment="Top" />
        </Grid>
      </Border>
      <DataTemplate.Triggers>
        <DataTrigger Binding="{Binding Path=(app:MainWindow.IsEditing), RelativeSource={RelativeSource Self}}" Value="True">
          <Setter TargetName="HeadingTextBlock" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="HeadingPlaceholder" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="InlineHeadingTextBox" Property="Visibility" Value="Visible" />
          <Setter TargetName="DescriptionTextBlock" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="InlineDescriptionTextBox" Property="Visibility" Value="Visible" />
          <Setter TargetName="EditIconPath" Property="Style" Value="{StaticResource BeatBoardCommitCheckIconStyle}" />
          <Setter TargetName="EditButton" Property="ToolTip" Value="Save changes" />
        </DataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding Path=(app:MainWindow.IsEditing), RelativeSource={RelativeSource Self}}" Value="False" />
            <Condition Binding="{Binding Heading}" Value="" />
          </MultiDataTrigger.Conditions>
          <Setter TargetName="HeadingTextBlock" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="HeadingPlaceholder" Property="Visibility" Value="Visible" />
        </MultiDataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding Path=(app:MainWindow.IsEditing), RelativeSource={RelativeSource Self}}" Value="False" />
            <Condition Binding="{Binding Heading}" Value="{x:Null}" />
          </MultiDataTrigger.Conditions>
          <Setter TargetName="HeadingTextBlock" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="HeadingPlaceholder" Property="Visibility" Value="Visible" />
        </MultiDataTrigger>
      </DataTemplate.Triggers>
    </DataTemplate>

    <views:BeatBoardCardTemplateSelector x:Key="BeatBoardCardTemplateSelector"
                                         ActTemplate="{StaticResource BeatBoardActCardTemplate}"
                                         SequenceTemplate="{StaticResource BeatBoardSequenceCardTemplate}"
                                         SceneTemplate="{StaticResource BeatBoardSceneCardTemplate}"
                                         NoteTemplate="{StaticResource BeatBoardNoteCardTemplate}"
                                         DefaultTemplate="{StaticResource BeatBoardDefaultCardTemplate}" />

    <views:BeatBoardCardTemplateSelector x:Key="BeatBoardOutlineCardTemplateSelector"
                                         ActTemplate="{StaticResource BeatBoardOutlineActCardTemplate}"
                                         SequenceTemplate="{StaticResource BeatBoardOutlineSequenceCardTemplate}"
                                         SceneTemplate="{StaticResource BeatBoardOutlineSceneCardTemplate}"
                                         NoteTemplate="{StaticResource BeatBoardOutlineNoteCardTemplate}"
                                         DefaultTemplate="{StaticResource BeatBoardOutlineDefaultCardTemplate}" />

    <Style x:Key="BeatBoardBoardItemContainerStyle" TargetType="ContentPresenter">
      <Setter Property="Margin" Value="0" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="views:BeatBoardWrapPanel.IsFullWidth" Value="False" />
      <Style.Triggers>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding Type}" Value="{x:Static parser:ScreenplayElementType.Section}" />
            <Condition Binding="{Binding Level}" Value="0" />
            <Condition Binding="{Binding IsCollapsed}" Value="False" />
          </MultiDataTrigger.Conditions>
          <Setter Property="views:BeatBoardWrapPanel.IsFullWidth" Value="True" />
        </MultiDataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding Type}" Value="{x:Static parser:ScreenplayElementType.Section}" />
            <Condition Binding="{Binding Level}" Value="1" />
            <Condition Binding="{Binding IsCollapsed}" Value="False" />
          </MultiDataTrigger.Conditions>
          <Setter Property="views:BeatBoardWrapPanel.IsFullWidth" Value="True" />
        </MultiDataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardOutlineItemContainerStyle" TargetType="ContentPresenter">
      <Setter Property="Margin" Value="0" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <ItemsPanelTemplate x:Key="BeatBoardWrapItemsPanelTemplate">
      <views:BeatBoardWrapPanel />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="BeatBoardOutlineItemsPanelTemplate">
      <StackPanel />
    </ItemsPanelTemplate>
  </Window.Resources>

  <Grid PreviewKeyDown="Window_PreviewKeyDown">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{DynamicResource SurfaceBackground}"
            BorderBrush="{DynamicResource SurfaceBorder}"
            BorderThickness="0,0,0,1"
            Padding="8,6,8,8">
      <DockPanel LastChildFill="False">
        <Menu DockPanel.Dock="Top"
              Background="Transparent"
              Margin="2,0,2,6">
          <MenuItem Header="_File">
            <MenuItem Header="_New" InputGestureText="Ctrl+N" Click="New_Click" />
            <MenuItem Header="_Open..." InputGestureText="Ctrl+O" Click="Open_Click" />
            <MenuItem Header="_Save" InputGestureText="Ctrl+S" Click="Save_Click" />
            <MenuItem Header="Save _As..." InputGestureText="Ctrl+Shift+S" Click="SaveAs_Click" />
            <MenuItem Header="_Close" InputGestureText="Ctrl+W" Click="CloseCurrent_Click" />
            <Separator />
            <MenuItem Header="_Export">
              <MenuItem.ItemsSource>
                <Binding Path="AvailableExporters" />
              </MenuItem.ItemsSource>
              <MenuItem.ItemContainerStyle>
                <Style TargetType="MenuItem"
                       BasedOn="{StaticResource {x:Type MenuItem}}">
                  <Setter Property="Header" Value="{Binding DisplayName}" />
                  <EventSetter Event="Click" Handler="ExportItem_Click" />
                </Style>
              </MenuItem.ItemContainerStyle>
            </MenuItem>
            <Separator />
            <MenuItem Header="E_xit" Click="Exit_Click" />
          </MenuItem>

          <MenuItem Header="_Edit">
            <MenuItem Header="_Undo" InputGestureText="Ctrl+Z" Click="Undo_Click" />
            <MenuItem Header="_Redo" InputGestureText="Ctrl+Y" Click="Redo_Click" />
            <Separator />
            <MenuItem Header="_Find / Replace..." InputGestureText="Ctrl+F" Click="Find_Click" />
          </MenuItem>

          <MenuItem Header="_View">
            <MenuItem Header="Zoom _In" InputGestureText="Ctrl++" Click="ZoomIn_Click" />
            <MenuItem Header="Zoom _Out" InputGestureText="Ctrl+-" Click="ZoomOut_Click" />
            <MenuItem Header="Reset _Zoom" InputGestureText="Ctrl+0" Click="ResetZoom_Click" />
          </MenuItem>

          <MenuItem Header="_Navigate">
            <MenuItem Header="Go to _Line..." InputGestureText="Ctrl+G" Click="GoToLine_Click" />
            <MenuItem Header="Go to _Scene..." InputGestureText="Ctrl+Shift+O" Click="GoToScene_Click" />
          </MenuItem>
        </Menu>

        <StackPanel DockPanel.Dock="Top"
                    Background="Transparent"
                    Margin="2,0,2,0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <StackPanel.Resources>
            <Style TargetType="Button">
              <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
              <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
              <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="Padding" Value="10,5" />
              <Setter Property="Margin" Value="0,0,6,0" />
              <Setter Property="MinWidth" Value="86" />
              <Setter Property="Cursor" Value="Hand" />
              <Setter Property="SnapsToDevicePixels" Value="True" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                      <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
                        <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                      </Trigger>
                      <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                      </Trigger>
                      <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                      </Trigger>
                      <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.55" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>

            <Style x:Key="ThemeSelectorComboBoxStyle" TargetType="ComboBox">
              <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
              <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
              <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="Padding" Value="6,2" />
              <Setter Property="MinWidth" Value="158" />
              <Setter Property="OverridesDefaultStyle" Value="True" />
              <Setter Property="SnapsToDevicePixels" Value="True" />
              <Setter Property="HorizontalContentAlignment" Value="Left" />
              <Setter Property="VerticalContentAlignment" Value="Center" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                      </Grid.ColumnDefinitions>

                      <ToggleButton x:Name="DropDownToggle"
                                    Grid.ColumnSpan="2"
                                    Focusable="False"
                                    ClickMode="Press"
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    OverridesDefaultStyle="True">
                        <ToggleButton.Template>
                          <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Border Background="Transparent" />
                          </ControlTemplate>
                        </ToggleButton.Template>
                      </ToggleButton>

                      <Border x:Name="ComboBorder"
                              Grid.ColumnSpan="2"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="2"
                              SnapsToDevicePixels="True"
                              IsHitTestVisible="False" />

                      <ContentPresenter x:Name="ContentSite"
                                        Grid.Column="0"
                                        Margin="{TemplateBinding Padding}"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                        ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        RecognizesAccessKey="True"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                        IsHitTestVisible="False"
                                        TextElement.Foreground="{TemplateBinding Foreground}" />

                      <Border Grid.Column="1"
                              Background="{DynamicResource SurfaceMutedBackground}"
                              BorderBrush="{DynamicResource ControlBorder}"
                              BorderThickness="1,0,0,0"
                              CornerRadius="0,2,2,0"
                              IsHitTestVisible="False">
                        <Path Data="M 0 0 L 5 5 L 10 0 Z"
                              Fill="{DynamicResource ControlForeground}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                      </Border>

                      <Popup x:Name="PART_Popup"
                             AllowsTransparency="True"
                             Focusable="False"
                             IsOpen="{TemplateBinding IsDropDownOpen}"
                             Placement="Bottom"
                             PlacementTarget="{Binding ElementName=DropDownToggle}"
                             PopupAnimation="Fade"
                             StaysOpen="False">
                        <Border Background="{DynamicResource SurfaceBackground}"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                Margin="0,2,0,0"
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                          <ScrollViewer CanContentScroll="True"
                                        HorizontalScrollBarVisibility="Disabled"
                                        VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                          </ScrollViewer>
                        </Border>
                      </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                      </Trigger>
                      <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                      </Trigger>
                      <Trigger Property="IsDropDownOpen" Value="True">
                        <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                        <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                      </Trigger>
                      <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.55" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </StackPanel.Resources>

          <Button Click="New_Click"
                  ToolTip="New document (Ctrl+N)"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE710;"
                         Foreground="{DynamicResource ControlAccent}"
                         Margin="0,0,6,0" />
              <TextBlock Text="New" />
            </StackPanel>
          </Button>

          <Button Click="Open_Click"
                  ToolTip="Open document (Ctrl+O)"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE8E5;"
                         Foreground="{DynamicResource ControlAccent}"
                         Margin="0,0,6,0" />
              <TextBlock Text="Open" />
            </StackPanel>
          </Button>

          <Button Click="Save_Click"
                  ToolTip="Save document (Ctrl+S)"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE74E;"
                         Foreground="{DynamicResource ControlAccent}"
                         Margin="0,0,6,0" />
              <TextBlock Text="Save" />
            </StackPanel>
          </Button>

          <Button Click="Find_Click"
                  ToolTip="Find and replace (Ctrl+F)"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE721;"
                         Foreground="{DynamicResource ControlAccent}"
                         Margin="0,0,6,0" />
              <TextBlock Text="Find" />
            </StackPanel>
          </Button>

          <Rectangle Width="1"
                     Height="26"
                     Margin="8,0,10,0"
                     Fill="{DynamicResource SurfaceBorder}"
                     VerticalAlignment="Center" />

          <Button x:Name="SyntaxQuickReferenceToggleButton"
                  Click="ToggleSyntaxQuickReference_Click"
                  ToolTip="Show syntax quick reference"
                  Style="{StaticResource DarkChromeButtonStyle}"
                  Padding="12,3"
                  VerticalAlignment="Center"
                  Content="Show Syntax"
                  Margin="0,0,8,0" />

          <Button Content="Title Page"
                  Click="TitlePage_Click"
                  Style="{StaticResource DarkChromeButtonStyle}"
                  Padding="12,3"
                  VerticalAlignment="Center"
                  Margin="0,0,12,0" />

          <ToggleButton x:Name="PreviewModeToggleButton"
                        Content="Preview"
                        Click="PreviewModeToggleButton_Click"
                        Style="{StaticResource DarkChromeToggleButtonStyle}"
                        Margin="0,0,12,0" />

            <TextBlock Text="Theme"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource SecondaryText}" />
            <ComboBox x:Name="ThemeComboBox"
                      Width="158"
                      Style="{StaticResource ThemeSelectorComboBoxStyle}"
                      Background="{DynamicResource ControlBackground}"
                      Foreground="{DynamicResource ControlForeground}"
                      BorderBrush="{DynamicResource ControlBorder}"
                      BorderThickness="1"
                      Padding="6,2"
                      SelectionChanged="ThemeComboBox_SelectionChanged">
              <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem"
                       BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                  <Setter Property="Padding" Value="8,4" />
                </Style>
              </ComboBox.ItemContainerStyle>
              <ComboBoxItem Content="Light" />
              <ComboBoxItem Content="Dark" />
              <ComboBoxItem Content="System Default" />
            </ComboBox>

          <StackPanel Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Documents.Count}" Value="0">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>

            <TextBlock Text="Open Files"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource SecondaryText}" />
            <ComboBox Width="220"
                      Style="{StaticResource ThemeSelectorComboBoxStyle}"
                      ItemsSource="{Binding Documents}"
                      SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                      ToolTip="Switch open file">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:MainWindowViewModel}">
                  <TextBlock Text="{Binding DisplayName}"
                             TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Click="CloseCurrent_Click"
                    ToolTip="Close current document (Ctrl+W)"
                    Width="30"
                    MinWidth="30"
                    Padding="0"
                    Margin="6,0,0,0">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE8BB;"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Button>
          </StackPanel>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="2"
          x:Name="MainLayoutGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="LeftDockColumn" Width="265" />
        <ColumnDefinition x:Name="LeftSplitterColumn" Width="6" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition x:Name="SyntaxQuickReferenceSplitterColumn" Width="0" />
        <ColumnDefinition x:Name="SyntaxQuickReferenceColumn" Width="0" />
      </Grid.ColumnDefinitions>

      <Border x:Name="LeftDockBorder"
              Grid.Column="0"
              Background="{DynamicResource SurfaceMutedBackground}"
              BorderBrush="{DynamicResource SurfaceMutedBorder}"
              BorderThickness="0,0,1,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Background="{DynamicResource SurfaceBackground}"
                  BorderBrush="{DynamicResource SurfaceMutedBorder}"
                  BorderThickness="0,0,0,1"
                  Padding="16,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock x:Name="LeftDockTitleText"
                         Text="Workspace"
                         FontSize="17"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource HeaderText}" />

              <Button x:Name="LeftDockToggleButton"
                      Grid.Column="1"
                      Click="ToggleLeftDock_Click"
                      Padding="8,2"
                      MinWidth="28"
                      Content="&lt;"
                      ToolTip="Collapse left dock"
                      Background="{DynamicResource ControlBackground}"
                      BorderBrush="{DynamicResource ControlBorder}" />
            </Grid>
          </Border>

          <TabControl x:Name="LeftDockTabs"
                      Grid.Row="1"
                      Margin="10,10,10,10"
                      Background="Transparent"
                      BorderThickness="0"
                      SelectedIndex="0">
            <TabControl.Resources>
              <Style x:Key="WorkspaceExpandToggleStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="20" />
                <Setter Property="Height" Value="20" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                      <Border x:Name="ChevronHost" Background="Transparent" CornerRadius="10">
                        <Path x:Name="ChevronPath"
                              Data="M 4 3 L 12 9 L 4 15 Z"
                              Width="9"
                              Height="9"
                              Fill="{DynamicResource MutedText}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Uniform"
                              RenderTransformOrigin="0.5,0.5" />
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="ChevronHost" Property="Background" Value="#18FFFFFF" />
                          <Setter TargetName="ChevronPath" Property="Fill" Value="{DynamicResource HeaderText}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                          <Setter TargetName="ChevronPath" Property="RenderTransform">
                            <Setter.Value>
                              <RotateTransform Angle="90" />
                            </Setter.Value>
                          </Setter>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>

              <Style x:Key="WorkspaceTreeItemStyle" TargetType="TreeViewItem">
                <Setter Property="Margin" Value="0,0,0,5" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Top" />
                <Setter Property="Foreground" Value="{DynamicResource WindowForeground}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ToggleButton x:Name="Expander"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      VerticalAlignment="Top"
                                      Margin="4,12,4,0">
                          <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                              <Setter Property="Template">
                                <Setter.Value>
                                  <ControlTemplate TargetType="ToggleButton">
                                    <Border Width="12" Height="12" Background="Transparent" SnapsToDevicePixels="True">
                                      <Path x:Name="ExpanderPath"
                                            Data="M 0 0 L 4 4 L 0 8 Z"
                                            Stroke="{DynamicResource SubtleText}"
                                            StrokeThickness="2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                          <RotateTransform Angle="0" />
                                        </Path.RenderTransform>
                                      </Path>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                      <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="ExpanderPath" Property="RenderTransform">
                                          <Setter.Value>
                                            <RotateTransform Angle="90" />
                                          </Setter.Value>
                                        </Setter>
                                      </Trigger>
                                      <Trigger Property="IsMouseOver" Value="True">
                                          <Setter TargetName="ExpanderPath" Property="Stroke" Value="{DynamicResource ControlAccent}" />
                                      </Trigger>
                                    </ControlTemplate.Triggers>
                                  </ControlTemplate>
                                </Setter.Value>
                              </Setter>
                            </Style>
                          </ToggleButton.Style>
                        </ToggleButton>

                        <ContentPresenter Grid.Column="1"
                                          x:Name="PART_Header"
                                          ContentSource="Header"
                                          HorizontalAlignment="Stretch" />
                        
                        <ItemsPresenter x:Name="ItemsHost"
                                        Grid.Column="1"
                                        Grid.Row="1"
                                        Visibility="Collapsed" />
                      </Grid>
                      <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                          <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="True">
                          <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>

              <Style x:Key="WorkspaceNodeCardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SurfaceMutedBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
                  </Trigger>
                  <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlAccent}" />
                    <Setter Property="Opacity" Value="0.25" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>

              <Style x:Key="WorkspaceNodeKindLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
                <Setter Property="FontSize" Value="9.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,2" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource HeaderText}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>

              <HierarchicalDataTemplate x:Key="WorkspaceNodeTemplate"
                                        DataType="{x:Type vm:OutlineNodeViewModel}"
                                        ItemsSource="{Binding Children}">
                <Border Padding="12,10"
                        Margin="0,0,12,6"
                        CornerRadius="10"
                        MinHeight="56"
                        Height="Auto"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True"
                        ToolTip="{Binding BodyText}"
                        MouseLeftButtonDown="WorkspaceNode_MouseLeftButtonDown"
                        MouseMove="WorkspaceNode_MouseMove"
                        DragOver="WorkspaceNode_DragOver"
                        Drop="WorkspaceNode_Drop"
                        DragLeave="WorkspaceNode_DragLeave"
                        Style="{StaticResource WorkspaceNodeCardBorderStyle}">

                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="28" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,1,0,0">
                      <TextBlock Text="{Binding LineNumber}"
                                 Foreground="{DynamicResource MutedText}"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Top"
                                 FontSize="10.5" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,4,0">
                      <StackPanel.Style>
                        <Style TargetType="StackPanel">
                          <Setter Property="Orientation" Value="Vertical" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                              <Setter Property="Orientation" Value="Horizontal" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </StackPanel.Style>
                      <TextBlock Text="{Binding KindLabel}">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock" BasedOn="{StaticResource WorkspaceNodeKindLabelStyle}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                <Setter Property="Margin" Value="0,0,8,0" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <TextBlock x:Name="HeadingText"
                                 Text="{Binding DisplayText}"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource WindowForeground}"
                                 FontSize="11.5">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Normal" />
                            <Setter Property="FontStyle" Value="Normal" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Kind}" Value="Section">
                                <Setter Property="FontWeight" Value="SemiBold" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Kind}" Value="SceneHeading">
                                <Setter Property="FontWeight" Value="Bold" />
                              </DataTrigger>

                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>

                    <ToggleButton Grid.Row="0" Grid.Column="2"
                                  Style="{StaticResource WorkspaceExpandToggleStyle}"
                                  IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                  VerticalAlignment="Top"
                                  Margin="0,-2,-4,0" />

                    <!-- Expanded Content -->
                    <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                               x:Name="FullContentText"
                               Text="{Binding BodyText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource WindowForeground}"
                               FontSize="11.5"
                               Margin="4,8,0,2"
                               Visibility="Collapsed" />
                  </Grid>
                </Border>
                <HierarchicalDataTemplate.Triggers>
                  <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter TargetName="FullContentText" Property="Visibility" Value="Visible" />
                    <Setter TargetName="HeadingText" Property="Visibility" Value="Visible" />
                  </DataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Kind}" Value="Note" />
                      <Condition Binding="{Binding IsExpanded}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="HeadingText" Property="Visibility" Value="Visible" />
                  </MultiDataTrigger>
                </HierarchicalDataTemplate.Triggers>
              </HierarchicalDataTemplate>
            </TabControl.Resources>

            <TabItem Header="Outline">
              <Grid Margin="-8,8,4,4">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        HorizontalAlignment="Right"
                        Margin="0,0,12,8"
                        Style="{StaticResource UtilityActionGroupBorderStyle}">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Cards"
                               Style="{StaticResource UtilityActionGroupLabelStyle}" />
                    <Button Command="{Binding SelectedDocument.ExpandAllOutlineNodesCommand}"
                            Content="Expand All"
                            Style="{StaticResource UtilityActionButtonStyle}"
                            Margin="0,0,6,0"
                            FontSize="10.5"
                            FontWeight="SemiBold"
                            IsEnabled="{Binding HasOutlineItems}"
                            ToolTip="Expand every outline card" />
                    <Button Command="{Binding SelectedDocument.CollapseAllOutlineNodesCommand}"
                            Content="Collapse All"
                            Style="{StaticResource UtilityActionButtonStyle}"
                            FontSize="10.5"
                            FontWeight="SemiBold"
                            IsEnabled="{Binding HasOutlineItems}"
                            ToolTip="Collapse every outline card" />
                  </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                  <TreeView x:Name="OutlineTree" 
                            AllowDrop="True" 
                            VirtualizingPanel.IsVirtualizing="False"
                            ItemsSource="{Binding OutlineRoots}"
                            Background="Transparent"
                            BorderThickness="0"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItemChanged="OutlineTree_SelectedItemChanged"
                            Focusable="False"
                            IsTabStop="False"
                            ItemContainerStyle="{StaticResource WorkspaceTreeItemStyle}"
                            ItemTemplate="{StaticResource WorkspaceNodeTemplate}"
                            TextOptions.TextFormattingMode="Ideal">
                  </TreeView>

                  <TextBlock Text="{Binding OutlineEmptyMessage}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             MaxWidth="180"
                             TextAlignment="Center"
                             Foreground="{DynamicResource MutedText}"
                             FontStyle="Italic"
                             FontSize="13"
                             TextWrapping="Wrap"
                             IsHitTestVisible="False">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding HasOutlineItems}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
 
                  <Canvas x:Name="WorkspaceDragCanvas" IsHitTestVisible="False">
                    <ContentControl x:Name="WorkspaceGhostVisual"
                                    Visibility="Collapsed"
                                    ContentTemplate="{StaticResource WorkspaceGhostTemplate}"
                                    IsHitTestVisible="False" />
                  </Canvas>
                </Grid>
              </Grid>
            </TabItem>

            <TabItem Header="Notes">
              <Grid Margin="-8,8,4,4">
                <Grid>
                  <TreeView x:Name="NotesTree" 
                            AllowDrop="True" 
                            VirtualizingPanel.IsVirtualizing="False"
                            ItemsSource="{Binding NotesRoots}"
                            Background="Transparent"
                            BorderThickness="0"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItemChanged="OutlineTree_SelectedItemChanged"
                            Focusable="False"
                            IsTabStop="False"
                            ItemContainerStyle="{StaticResource WorkspaceTreeItemStyle}"
                            ItemTemplate="{StaticResource WorkspaceNodeTemplate}"
                            TextOptions.TextFormattingMode="Ideal" />

                  <TextBlock Text="{Binding NotesEmptyMessage}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             MaxWidth="180"
                             TextAlignment="Center"
                             Foreground="{DynamicResource MutedText}"
                             FontStyle="Italic"
                             FontSize="13"
                             TextWrapping="Wrap"
                             IsHitTestVisible="False">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding HasNoteItems}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
 
                  <Canvas x:Name="NotesDragCanvas" IsHitTestVisible="False">
                    <ContentControl x:Name="NotesGhostVisual"
                                    Visibility="Collapsed"
                                    ContentTemplate="{StaticResource WorkspaceGhostTemplate}"
                                    IsHitTestVisible="False" />
                  </Canvas>
                </Grid>
              </Grid>
            </TabItem>

            <TabItem Header="Scratchpad">
              <Grid Margin="0,8,4,4">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,10">
                  <TextBlock Text="Search Scratchpad"
                             Foreground="{DynamicResource SecondaryText}"
                             FontSize="11"
                             FontWeight="SemiBold"
                             Margin="0,0,0,4" />
                  <TextBox Text="{Binding ScratchpadSearchText, UpdateSourceTrigger=PropertyChanged}"
                           Background="{DynamicResource ControlBackground}"
                           Foreground="{DynamicResource ControlForeground}"
                           BorderBrush="{DynamicResource ControlBorder}"
                           BorderThickness="1"
                           Padding="8,6" />
                </StackPanel>

                <Grid Grid.Row="1">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <Grid.Resources>
                    <Style x:Key="ScratchpadActionButtonStyle" TargetType="Button">
                      <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                      <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                      <Setter Property="BorderThickness" Value="1" />
                      <Setter Property="Padding" Value="8,3" />
                      <Setter Property="Cursor" Value="Hand" />
                      <Setter Property="SnapsToDevicePixels" Value="True" />
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                              <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                              </Trigger>
                              <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                              </Trigger>
                            </ControlTemplate.Triggers>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>

                    <Style x:Key="ScratchpadActionToggleButtonStyle" TargetType="ToggleButton">
                      <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                      <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
                      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                      <Setter Property="BorderThickness" Value="1" />
                      <Setter Property="Padding" Value="8,3" />
                      <Setter Property="Cursor" Value="Hand" />
                      <Setter Property="SnapsToDevicePixels" Value="True" />
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                              <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                              <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                              </Trigger>
                              <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceBackground}" />
                              </Trigger>
                              <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                              </Trigger>
                            </ControlTemplate.Triggers>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </Grid.Resources>

                  <ListBox Grid.Row="0"
                           ItemsSource="{Binding ScratchpadElements}"
                           SelectedItem="{Binding SelectedScratchpadElement, Mode=TwoWay}"
                           Background="Transparent"
                           BorderThickness="0"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                           VirtualizingPanel.ScrollUnit="Pixel" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                      <Style TargetType="ListBoxItem"
                             BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                      </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Padding="12"
                                Background="{DynamicResource SurfaceRaisedBackground}"
                                BorderBrush="{DynamicResource SurfaceMutedBorder}"
                                BorderThickness="1"
                                CornerRadius="8">
                          <Grid>
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>

                              <StackPanel>
                                <TextBlock Text="{Binding KindLabel}"
                                           Foreground="{DynamicResource ControlAccent}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBlock Text="{Binding Heading}"
                                           Foreground="{DynamicResource HeaderText}"
                                           FontSize="12.5"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                              </StackPanel>

                              <ToggleButton Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Top"
                                            IsChecked="{Binding IsCollapsed, Mode=TwoWay}">
                                <ToggleButton.Style>
                                  <Style TargetType="ToggleButton"
                                         BasedOn="{StaticResource ScratchpadActionToggleButtonStyle}">
                                    <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
                                    <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                                    <Setter Property="Padding" Value="8,3" />
                                    <Setter Property="MinWidth" Value="68" />
                                    <Setter Property="Content" Value="Collapse" />
                                    <Style.Triggers>
                                      <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="Expand" />
                                      </Trigger>
                                    </Style.Triggers>
                                  </Style>
                                </ToggleButton.Style>
                              </ToggleButton>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding PreviewText}"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="11.5"
                                       Margin="0,10,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Visibility" Value="Visible" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCollapsed}" Value="False">
                                      <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Grid.Row="2"
                                       Text="{Binding Description}"
                                       Foreground="{DynamicResource WindowForeground}"
                                       FontSize="11.5"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Visibility" Value="Visible" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                      <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <TextBlock Grid.Row="0"
                             Text="{Binding ScratchpadEmptyMessage}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             MaxWidth="180"
                             TextAlignment="Center"
                             Foreground="{DynamicResource MutedText}"
                             FontStyle="Italic"
                             FontSize="13"
                             TextWrapping="Wrap"
                             IsHitTestVisible="False">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding HasScratchpadItems}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>

                  <Button Grid.Row="1"
                          Style="{StaticResource ScratchpadActionButtonStyle}"
                          Command="{Binding DeleteScratchpadCardCommand}"
                          HorizontalAlignment="Right"
                          Margin="0,10,0,0"
                          Width="38"
                          Height="34"
                          Padding="0"
                          ToolTip="Delete selected scratchpad card">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE74D;"
                               FontSize="15"
                               Foreground="{DynamicResource ControlForeground}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Button>
                </Grid>
              </Grid>
            </TabItem>

            <TabItem Header="Goal">
              <views:GoalPanel Margin="2,8,2,2" />
            </TabItem>
          </TabControl>
        </Grid>
      </Border>

      <GridSplitter x:Name="LeftSplitter"
                    Grid.Column="1"
                    Width="6"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource SurfaceBorder}" />

      <Border Grid.Column="2"
              Background="{DynamicResource SurfaceRaisedBackground}"
              BorderBrush="{DynamicResource SurfaceBorder}"
              BorderThickness="0">
        <DockPanel LastChildFill="True">
          <Border DockPanel.Dock="Top"
                  Background="{DynamicResource SurfaceBackground}"
                  BorderBrush="{DynamicResource SurfaceMutedBorder}"
                  BorderThickness="0,0,0,1"
                  Padding="18,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock x:Name="WorkspaceTitleText"
                         Text="Editor"
                         FontSize="17"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource HeaderText}"
                         VerticalAlignment="Center" />

              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <StackPanel.Resources>
                  <Style TargetType="ToggleButton">
                    <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                    <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Padding" Value="10,5" />
                    <Setter Property="Margin" Value="0,0,8,0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                          <Border x:Name="WorkspaceModeBorder"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="4"
                                  Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                              <Setter TargetName="WorkspaceModeBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
                              <Setter TargetName="WorkspaceModeBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="WorkspaceModeBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
                              <Setter TargetName="WorkspaceModeBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                              <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </StackPanel.Resources>

                <ToggleButton x:Name="EditorWorkspaceButton"
                              Content="Editor"
                              IsChecked="True"
                              Click="EditorWorkspaceButton_Click" />
                <ToggleButton x:Name="BeatBoardWorkspaceButton"
                              Content="Beat Board"
                              Margin="0"
                              Click="BeatBoardWorkspaceButton_Click" />
              </StackPanel>
            </Grid>
          </Border>

          <Grid>
            <ScrollViewer x:Name="EditorScrollHost"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          CanContentScroll="False"
                          PanningMode="Both"
                          PreviewMouseWheel="EditorScrollHost_PreviewMouseWheel"
                          ScrollChanged="EditorScrollHost_ScrollChanged"
                          SizeChanged="EditorScrollHost_SizeChanged">
              <Grid x:Name="EditorDocumentHost"
                    Width="800"
                    Margin="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
                <Grid.LayoutTransform>
                  <ScaleTransform ScaleX="{Binding EditorZoomScale}"
                                  ScaleY="{Binding EditorZoomScale}" />
                </Grid.LayoutTransform>
                <AdornerDecorator>
                  <RichTextBox x:Name="EditorBox"
                               Padding="50"
                               IsReadOnly="{Binding IsBoardModeActive}"
                               IsHitTestVisible="True"
                               IsDocumentEnabled="True"
                               IsInactiveSelectionHighlightEnabled="True"
                               AcceptsReturn="True"
                               AcceptsTab="True"
                               InputMethod.IsInputMethodEnabled="False"
                               HorizontalContentAlignment="Stretch"
                               Loaded="EditorBox_Loaded"
                               SizeChanged="EditorBox_SizeChanged"
                               GotFocus="EditorBox_GotFocus"
                               LostKeyboardFocus="EditorBox_LostKeyboardFocus"
                               TextChanged="EditorBox_TextChanged"
                               PreviewTextInput="EditorBox_PreviewTextInput"
                               PreviewKeyDown="EditorBox_PreviewKeyDown"
                               RequestBringIntoView="EditorBox_RequestBringIntoView"
                               SelectionChanged="EditorBox_SelectionChanged"
                               VerticalScrollBarVisibility="Disabled"
                               HorizontalScrollBarVisibility="Disabled"
                               BorderThickness="0"
                               BorderBrush="Transparent"
                               Background="{DynamicResource WindowBackground}"
                               Foreground="{DynamicResource EditorForeground}"
                               SelectionBrush="{DynamicResource ControlAccent}"
                               CaretBrush="{DynamicResource EditorForeground}"
                               FontFamily="Courier Prime, Courier New, Courier"
                               FontSize="16"
                               VerticalAlignment="Stretch"
                               TextOptions.TextFormattingMode="Display">
                    <RichTextBox.ContextMenu>
                      <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Move to Scratchpad"
                                  Command="{Binding MoveToScratchpadCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget}" />
                      </ContextMenu>
                    </RichTextBox.ContextMenu>
                    <FlowDocument PagePadding="50">
                      <Paragraph Margin="0">
                        <Run Text="" />
                      </Paragraph>
                    </FlowDocument>
                  </RichTextBox>
                </AdornerDecorator>
              </Grid>
            </ScrollViewer>

            <Grid x:Name="BeatBoardWorkspaceHost"
                  Visibility="Collapsed"
                  Margin="18,14,18,18">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                  <Button Command="{Binding CreateNewCardCommand}"
                          Style="{StaticResource DarkChromeButtonStyle}"
                          Padding="12,6"
                          MinWidth="94"
                          Margin="0,0,8,0"
                          ToolTip="Create a new draft board card">
                    <TextBlock Text="New Card"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                  </Button>

                  <Button Command="{Binding SyncBoardToScriptCommand}"
                          Style="{StaticResource DarkChromeButtonStyle}"
                          Padding="12,6"
                          MinWidth="124"
                          Background="{DynamicResource ControlBackground}"
                          Foreground="{DynamicResource ControlForeground}"
                          BorderBrush="{DynamicResource ControlBorder}"
                          BorderThickness="1"
                          ToolTip="Apply the Beat Board structure back to the script">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="Sync to Script"
                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                      <Ellipse Width="8"
                               Height="8"
                               Margin="8,0,0,0"
                               Fill="#FFF0A23B"
                               VerticalAlignment="Center"
                               Visibility="Collapsed">
                        <Ellipse.Style>
                          <Style TargetType="Ellipse">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsBoardSyncRequired}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Ellipse.Style>
                      </Ellipse>
                    </StackPanel>
                  </Button>

                  <Border Margin="8,0,0,0"
                          Style="{StaticResource UtilityActionGroupBorderStyle}">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="Cards"
                                 Style="{StaticResource UtilityActionGroupLabelStyle}" />
                      <Button Command="{Binding SelectedDocument.ExpandAllBoardCardsCommand}"
                              Content="Expand All"
                              Style="{StaticResource UtilityActionButtonStyle}"
                              Margin="0,0,6,0"
                              FontSize="10.5"
                              FontWeight="SemiBold"
                              IsEnabled="{Binding HasBoardItems}"
                              ToolTip="Expand every beat board card" />
                      <Button Command="{Binding SelectedDocument.CollapseAllBoardCardsCommand}"
                              Content="Collapse All"
                              Style="{StaticResource UtilityActionButtonStyle}"
                              FontSize="10.5"
                              FontWeight="SemiBold"
                              IsEnabled="{Binding HasBoardItems}"
                              ToolTip="Collapse every beat board card" />
                    </StackPanel>
                  </Border>

                  <Border Margin="12,0,0,0"
                          BorderBrush="{DynamicResource ControlBorder}"
                          BorderThickness="1"
                          CornerRadius="5">
                    <StackPanel Orientation="Horizontal">
                      <ToggleButton x:Name="BeatBoardBoardViewButton"
                                    Content="Board"
                                    Style="{StaticResource BeatBoardViewToggleButtonStyle}"
                                    IsChecked="True"
                                    ToolTip="Hierarchical board layout"
                                    Click="BeatBoardBoardViewButton_Click" />
                      <ToggleButton x:Name="BeatBoardOutlineViewButton"
                                    Content="Outline"
                                    Style="{StaticResource BeatBoardViewToggleButtonStyle}"
                                    ToolTip="Vertical chronological layout"
                                    Click="BeatBoardOutlineViewButton_Click" />
                    </StackPanel>
                  </Border>
                </StackPanel>

                <TextBlock DockPanel.Dock="Right"
                           Text="Drag cards to reorder hierarchy blocks or drop them in the bin to delete"
                           Margin="18,0,0,0"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="11"
                           VerticalAlignment="Center" />
              </DockPanel>

              <Grid x:Name="BeatBoardSurfaceRoot"
                    Grid.Row="1"
                    SizeChanged="BeatBoardSurfaceRoot_SizeChanged">
                <ScrollViewer x:Name="BeatBoardScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              PreviewMouseWheel="BeatBoardScrollViewer_PreviewMouseWheel"
                              CanContentScroll="False">
                  <Grid x:Name="BeatBoardContentHost"
                        MinWidth="300">
                    <Grid.LayoutTransform>
                      <ScaleTransform ScaleX="{Binding SelectedDocument.BoardZoomScale}"
                                      ScaleY="{Binding SelectedDocument.BoardZoomScale}" />
                    </Grid.LayoutTransform>
                    <ItemsControl x:Name="BeatBoard"
                                  ItemsSource="{Binding SelectedDocument.VisibleBoardElements}"
                                  ItemTemplateSelector="{StaticResource BeatBoardCardTemplateSelector}"
                                  ItemContainerStyle="{StaticResource BeatBoardBoardItemContainerStyle}"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="BeatBoard_PreviewMouseLeftButtonDown"
                                  PreviewMouseLeftButtonUp="BeatBoard_PreviewMouseLeftButtonUp"
                                  PreviewMouseMove="BeatBoard_PreviewMouseMove"
                                  DragOver="BeatBoard_DragOver"
                                  DragLeave="BeatBoard_DragLeave"
                                  Drop="BeatBoard_Drop"
                                  GiveFeedback="BeatBoard_GiveFeedback"
                                  QueryContinueDrag="BeatBoard_QueryContinueDrag">
                      <ItemsControl.ItemsPanel>
                        <StaticResource ResourceKey="BeatBoardWrapItemsPanelTemplate" />
                      </ItemsControl.ItemsPanel>
                    </ItemsControl>

                  </Grid>
                </ScrollViewer>

                <TextBlock Text="Acts, sequences, scenes, and notes will appear here."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MaxWidth="240"
                           TextAlignment="Center"
                           Foreground="{DynamicResource MutedText}"
                           FontStyle="Italic"
                           FontSize="13"
                           TextWrapping="Wrap"
                           IsHitTestVisible="False">
                  <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedDocument.HasVisibleBoardItems}" Value="False">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        </Style.Triggers>
                      </Style>
                  </TextBlock.Style>
                </TextBlock>

                <Button x:Name="BeatBoardDeleteButton"
                        Width="44"
                        Height="38"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,12,12"
                        Panel.ZIndex="12"
                        AllowDrop="True"
                        Click="BeatBoardDeleteButton_Click"
                        DragOver="BeatBoardDeleteButton_DragOver"
                        DragLeave="BeatBoardDeleteButton_DragLeave"
                        Drop="BeatBoardDeleteButton_Drop"
                        Style="{StaticResource DarkChromeButtonStyle}"
                        Background="{DynamicResource ControlBackground}"
                        Foreground="{DynamicResource ControlForeground}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1"
                        ToolTip="Delete the selected beat board block from the board and script">
                  <TextBlock FontFamily="Segoe MDL2 Assets"
                             Text="&#xE74D;"
                             FontSize="15"
                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Button>

                <Canvas x:Name="BeatBoardDragGhostHost"
                        IsHitTestVisible="False"
                        Panel.ZIndex="11" />
              </Grid>
            </Grid>

            <ScrollViewer x:Name="PreviewWorkspaceHost"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{DynamicResource SurfaceRaisedBackground}"
                          PreviewMouseWheel="PreviewWorkspaceHost_PreviewMouseWheel">
              <ItemsControl x:Name="PreviewPagesControl"
                            Margin="0,20,0,20"
                            HorizontalAlignment="Center"
                            VirtualizingPanel.IsVirtualizing="True">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Width="612" Height="792" Margin="0,0,0,20" Background="{DynamicResource WindowBackground}" CornerRadius="2">
                      <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.1" ShadowDepth="2" />
                      </Border.Effect>
                      <Grid>
                        <ItemsControl ItemsSource="{Binding Lines}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas Width="612" Height="792" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding Text}"
                                         FontFamily="Courier Prime, Courier New, Courier"
                                         FontSize="12"
                                         Foreground="{DynamicResource EditorForeground}">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsBold}" Value="True">
                                        <Setter Property="FontWeight" Value="Bold" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                          <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                              <Setter Property="Canvas.Left" Value="{Binding X}" />
                              <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                          </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                        <TextBlock Text="{Binding PageNumberLabel}" 
                                   FontFamily="Courier Prime, Courier New, Courier" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource EditorForeground}" 
                                   HorizontalAlignment="Right" 
                                   VerticalAlignment="Top" 
                                   Margin="0,36,72,0" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </DockPanel>
      </Border>

      <GridSplitter x:Name="SyntaxQuickReferenceSplitter"
                    Grid.Column="3"
                    Width="6"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource SurfaceBorder}"
                    Visibility="Collapsed" />

      <Border x:Name="SyntaxQuickReferenceBorder"
              Grid.Column="4"
              Background="{DynamicResource SurfaceBackground}"
              BorderBrush="{DynamicResource SurfaceBorder}"
              BorderThickness="1,0,0,0"
              Visibility="Collapsed">
        <views:SyntaxQuickReferencePanel />
      </Border>

    </Grid>

    <Border Grid.Row="3"
            Background="{DynamicResource SurfaceBackground}"
            BorderBrush="{DynamicResource SurfaceBorder}"
            BorderThickness="0,1,0,0"
            Padding="14,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="18" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="18" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="18" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource MutedText}"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis" />

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <TextBlock Text="Line "
                     Foreground="{DynamicResource SecondaryText}"
                     FontSize="12"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding CurrentLineNumber}"
                     Foreground="{DynamicResource WindowForeground}"
                     FontSize="12" />
          <TextBlock Text="  Type "
                     Foreground="{DynamicResource SecondaryText}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Margin="10,0,0,0" />
          <TextBlock Text="{Binding CurrentElementType}"
                     Foreground="{DynamicResource WindowForeground}"
                     FontSize="12" />
        </StackPanel>

        <TextBlock Grid.Column="4"
                   Text="{Binding CurrentElementText}"
                   Foreground="{DynamicResource MutedText}"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center" />

        <StackPanel Grid.Column="6"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <TextBlock Text="Zoom "
                     Foreground="{DynamicResource SecondaryText}"
                     FontWeight="SemiBold"
                     FontSize="12"
                     Margin="0,0,4,0" />
          <TextBlock Text="{Binding ActiveZoomDisplayText}"
                     Foreground="{DynamicResource WindowForeground}"
                     FontSize="12"
                     Margin="0,0,12,0" />
          <TextBlock x:Name="txtModeStatus"
                     Text="MODE: SCREENPLAY"
                     Foreground="{DynamicResource WindowForeground}"
                     FontWeight="SemiBold"
                     FontSize="12"
                     Margin="0,0,12,0" />
          <TextBlock Text="Enter "
                     Foreground="{DynamicResource SecondaryText}"
                     FontWeight="SemiBold"
                     FontSize="12" />
          <TextBlock Text="{Binding EnterContinuationText}"
                     Foreground="{DynamicResource WindowForeground}"
                     FontSize="12"
                     Margin="0,0,12,0" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>

