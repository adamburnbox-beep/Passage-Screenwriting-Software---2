<Window x:Class="Passage.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Passage.App.Converters"
        xmlns:parser="clr-namespace:Passage.Parser;assembly=Passage.Parser"
        xmlns:views="clr-namespace:Passage.App.Views"
        xmlns:vm="clr-namespace:Passage.App.ViewModels"
        xmlns:app="clr-namespace:Passage.App"
        Title="{Binding WindowTitle}"
        Width="1320"
        Height="800"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="Manual"
        Background="{DynamicResource WindowBackground}">
  <Window.Resources>
    <ControlTemplate x:Key="BeatBoardWatermarkTextBoxTemplate" TargetType="TextBox">
      <Grid>
        <Border x:Name="Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                Padding="{TemplateBinding Padding}"
                CornerRadius="2">
          <ScrollViewer x:Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" />
        </Border>
        <TextBlock x:Name="Placeholder"
                   Text="{TemplateBinding Tag}"
                   Foreground="{TemplateBinding Foreground}"
                   Opacity="0.4"
                   FontStyle="Italic"
                   IsHitTestVisible="False"
                   Margin="5,3,5,0"
                   Visibility="Collapsed"
                   TextWrapping="Wrap" />
      </Grid>
      <ControlTemplate.Triggers>
        <Trigger Property="Text" Value="">
          <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
        </Trigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="BeatBoardInlineTextBoxStyle" TargetType="TextBox">
      <Setter Property="Visibility" Value="Collapsed" />
      <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource HeaderText}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="Margin" Value="0,0,0,4" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="AcceptsReturn" Value="False" />
      <Setter Property="Template" Value="{StaticResource BeatBoardWatermarkTextBoxTemplate}" />
    </Style>

    <Style x:Key="BeatBoardInlineComboBoxStyle" TargetType="ComboBox">
      <Setter Property="Visibility" Value="Collapsed" />
      <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="Margin" Value="0,0,8,4" />
      <Setter Property="FontFamily" Value="Courier Prime, Courier New, Courier" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton x:Name="ToggleButton"
                            Background="{TemplateBinding Background}"
                            Foreground="{TemplateBinding Foreground}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                            Padding="{TemplateBinding Padding}"
                            ClickMode="Press">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="templateRoot" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="2">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="18" />
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0" 
                                          Margin="{TemplateBinding Padding}" 
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Left" 
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        <Path Grid.Column="1" 
                              Data="M0,0 L4,4 L8,0 Z" 
                              Fill="{DynamicResource MutedText}" 
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center" />
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="true">
                        <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource SurfaceRaisedBackground}"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>
              <ContentPresenter x:Name="ContentSite"
                                IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left" />
              <Popup x:Name="Popup"
                     Placement="Bottom"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     AllowsTransparency="True"
                     Focusable="False"
                     PopupAnimation="Slide">
                <Border x:Name="DropDownBorder"
                        Background="{DynamicResource SurfaceBackground}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1"
                        MinWidth="{TemplateBinding ActualWidth}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                  <ScrollViewer SnapsToDevicePixels="True">
                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="HasItems" Value="false">
                <Setter TargetName="DropDownBorder" Property="Height" Value="0"/>
              </Trigger>
              <Trigger Property="IsGrouping" Value="true">
                <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BeatBoardInlineDescriptionTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource BeatBoardInlineTextBoxStyle}">
      <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="AcceptsReturn" Value="True" />
      <Setter Property="MinLines" Value="3" />
      <Setter Property="MaxLines" Value="8" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="Template" Value="{StaticResource BeatBoardWatermarkTextBoxTemplate}" />
      <Setter Property="Tag" Value="Click the pencil to edit. Double-click to locate in script." />
    </Style>

    <local:UppercaseConverter x:Key="UppercaseConverter" />
    <local:EqualityConverter x:Key="EqualityConverter" />
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <DataTemplate x:Key="WorkspaceGhostTemplate" DataType="{x:Type vm:OutlineNodeViewModel}">
      <Border Padding="12,10"
              CornerRadius="10"
              Width="240"
              Height="60"
              Background="{DynamicResource SurfaceMutedBackground}"
              BorderBrush="{DynamicResource ControlAccent}"
              BorderThickness="1"
              Opacity="0.5">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="28" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" 
                     Text="{Binding LineNumber}"
                     Foreground="{DynamicResource MutedText}"
                     FontSize="10.5" />
          <StackPanel Grid.Column="1" Margin="4,0,0,0">
            <TextBlock Text="{Binding KindLabel, Converter={StaticResource UppercaseConverter}}"
                       Foreground="{DynamicResource SecondaryText}"
                       FontSize="9.5"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding Heading}"
                       Foreground="{DynamicResource HeaderText}"
                       FontSize="13.5"
                       FontWeight="Bold"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>


    <Style x:Key="UtilityActionGroupBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="7,5" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="UtilityActionGroupLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
      <Setter Property="FontSize" Value="9.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style x:Key="UtilityActionButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DarkChromeButtonStyle}">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource HeaderText}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="24" />
    </Style>

    <Style x:Key="BeatBoardTypeSelectorStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource BeatBoardDefaultCardAccentForeground}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Arrow" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="BeatBoardTypeSelectorHostStyle" TargetType="StackPanel">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="BeatBoardHeadingStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource HeaderText}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Style.Triggers>
        <Trigger Property="Text" Value="">
          <Setter Property="Opacity" Value="0.4" />
          <Setter Property="FontStyle" Value="Italic" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardDescriptionStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Margin" Value="0,10,0,0" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Visibility" Value="Visible" />
      <Style.Triggers>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardSceneHeadingStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Margin" Value="0,8,0,0" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Visibility" Value="Visible" />
      <Style.Triggers>
        <Trigger Property="Text" Value="">
          <Setter Property="Opacity" Value="0.4" />
          <Setter Property="FontStyle" Value="Italic" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardCollapseChevronButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Width" Value="20" />
      <Setter Property="Height" Value="20" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Focusable" Value="False" />
      <EventSetter Event="PreviewMouseLeftButtonDown" Handler="BeatBoardCollapseButton_PreviewMouseLeftButtonDown" />
      <EventSetter Event="Click" Handler="BeatBoardCollapseButton_Click" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ChevronHost"
                    Background="Transparent"
                    CornerRadius="10">
              <Path x:Name="ChevronPath"
                    Data="M 4 3 L 12 9 L 4 15 Z"
                    Width="10"
                    Height="10"
                    Fill="{TemplateBinding Foreground}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Stretch="Uniform"
                    RenderTransformOrigin="0.5,0.5">
                <Path.RenderTransform>
                  <RotateTransform Angle="90" />
                </Path.RenderTransform>
              </Path>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ChevronHost" Property="Background" Value="#18FFFFFF" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ChevronHost" Property="Background" Value="#28FFFFFF" />
              </Trigger>
              <DataTrigger Binding="{Binding DataContext.IsCollapsed, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                <Setter TargetName="ChevronPath" Property="RenderTransform">
                  <Setter.Value>
                    <RotateTransform Angle="0" />
                  </Setter.Value>
                </Setter>
              </DataTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BeatBoardIconButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#FFE7DCCF" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Width" Value="20" />
      <Setter Property="Height" Value="20" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Focusable" Value="False" />
      <EventSetter Event="PreviewMouseLeftButtonDown" Handler="BeatBoardActionButton_PreviewMouseLeftButtonDown" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="IconHost"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="IconHost" Property="Background" Value="#18FFFFFF" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="IconHost" Property="Background" Value="#28FFFFFF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#7FAFA296" />
                <Setter TargetName="IconHost" Property="Background" Value="#10000000" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BeatBoardCompactIconButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource BeatBoardIconButtonStyle}">
      <Setter Property="Width" Value="14" />
      <Setter Property="Height" Value="14" />
    </Style>

    <Style x:Key="BeatBoardPencilIconStyle" TargetType="Path">
      <Setter Property="Data" Value="M 3 13.5 L 3 17 L 6.5 17 L 14.5 9 L 11 5.5 Z M 10.4 6.1 L 13.9 9.6 M 12.1 4.5 L 15.5 7.9" />
      <Setter Property="Width" Value="12" />
      <Setter Property="Height" Value="12" />
      <Setter Property="Stretch" Value="Uniform" />
      <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
      <Setter Property="StrokeThickness" Value="1.35" />
      <Setter Property="StrokeStartLineCap" Value="Round" />
      <Setter Property="StrokeEndLineCap" Value="Round" />
      <Setter Property="StrokeLineJoin" Value="Round" />
    </Style>

    <Style x:Key="BeatBoardCompactPencilIconStyle"
           TargetType="Path"
           BasedOn="{StaticResource BeatBoardPencilIconStyle}">
      <Setter Property="Width" Value="9" />
      <Setter Property="Height" Value="9" />
      <Setter Property="StrokeThickness" Value="1.05" />
    </Style>

    <Style x:Key="BeatBoardBoardEditButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource BeatBoardCompactIconButtonStyle}">
      <Setter Property="Visibility" Value="Visible" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
          <Setter Property="Visibility" Value="Collapsed" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardCommitCheckIconStyle" TargetType="Path">
      <Setter Property="Data" Value="M 2.5 8 L 6.2 11.7 L 13.5 4.5" />
      <Setter Property="Width" Value="14" />
      <Setter Property="Height" Value="14" />
      <Setter Property="Stretch" Value="Uniform" />
      <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
      <Setter Property="StrokeThickness" Value="1.8" />
      <Setter Property="StrokeStartLineCap" Value="Round" />
      <Setter Property="StrokeEndLineCap" Value="Round" />
      <Setter Property="StrokeLineJoin" Value="Round" />
    </Style>

    <Style x:Key="BeatBoardViewToggleButtonStyle" TargetType="ToggleButton">
      <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource ControlForeground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="BeatBoardViewModeBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="BeatBoardViewModeBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
                <Setter TargetName="BeatBoardViewModeBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="BeatBoardViewModeBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBackground}" />
                <Setter TargetName="BeatBoardViewModeBorder" Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BeatBoardOutlineCardBorderBaseStyle" TargetType="Border">
      <Setter Property="Margin" Value="68,0,18,10" />
      <Setter Property="Padding" Value="14,13" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Level}" Value="0">
          <Setter Property="Margin" Value="0,0,18,14" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Level}" Value="1">
          <Setter Property="Margin" Value="24,0,18,12" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Level}" Value="2">
          <Setter Property="Margin" Value="48,0,18,10" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
          <Setter Property="Padding" Value="14,10" />
        </DataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Value="True">
              <Condition.Binding>
                <MultiBinding Converter="{StaticResource EqualityConverter}">
                  <Binding />
                  <Binding Path="DataContext.SelectedDocument.BoardDropTargetElement" RelativeSource="{RelativeSource AncestorType=Window}" />
                </MultiBinding>
              </Condition.Binding>
            </Condition>
          </MultiDataTrigger.Conditions>
          <Setter Property="Background" Value="{DynamicResource ControlAccent}" />
          <Setter Property="Opacity" Value="0.25" />
        </MultiDataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardOutlineActCardBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource BeatBoardOutlineCardBorderBaseStyle}">
      <Setter Property="Padding" Value="18,15" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SurfaceMutedBorder}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsCollapsed}" Value="False">
          <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
          <Setter Property="Padding" Value="18,10" />
          <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
          <Setter Property="BorderBrush" Value="{DynamicResource SurfaceMutedBorder}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardOutlineSequenceCardBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource BeatBoardOutlineCardBorderBaseStyle}">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SurfaceMutedBorder}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsCollapsed}" Value="False">
          <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardOutlineSceneCardBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource BeatBoardOutlineCardBorderBaseStyle}">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SurfaceMutedBorder}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsCollapsed}" Value="False">
          <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardOutlineNoteCardBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource BeatBoardOutlineCardBorderBaseStyle}">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SurfaceMutedBorder}" />
      <Setter Property="CornerRadius" Value="10" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsCollapsed}" Value="False">
          <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardOutlineDefaultCardBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource BeatBoardOutlineCardBorderBaseStyle}">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SurfaceMutedBorder}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsCollapsed}" Value="False">
          <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BeatBoardOutlineTypeSelectorStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BeatBoardTypeSelectorStyle}">
      <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="BeatBoardOutlineTypeSelectorHostStyle" TargetType="StackPanel">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="BeatBoardTypeSelectorTriangleStyle" TargetType="Path">
      <Setter Property="Data" Value="M 0 0 L 8 0 L 4 5 Z" />
      <Setter Property="Width" Value="8" />
      <Setter Property="Height" Value="5" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Stretch" Value="Fill" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="Margin" Value="0,4,6,0" />
    </Style>

    <Style x:Key="BeatBoardOutlineHeadingStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BeatBoardHeadingStyle}">
      <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="BeatBoardOutlineDescriptionStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BeatBoardDescriptionStyle}">
      <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

    <Style x:Key="BeatBoardOutlineSceneHeadingStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BeatBoardSceneHeadingStyle}">
      <Setter Property="Margin" Value="0,5,0,0" />
    </Style>

    <DataTemplate x:Key="BeatBoardActCardTemplate">
      <Border Margin="0,0,0,16"
              BorderThickness="1"
              Cursor="Hand"
              MouseLeftButtonDown="BeatBoardCard_MouseLeftButtonDown"
              MouseLeftButtonUp="BeatBoardCard_MouseLeftButtonUp">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlAccent}" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                <Setter Property="Padding" Value="4,2,4,2" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Background" Value="{DynamicResource SurfaceMutedBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SurfaceMutedBorder}" />
              </DataTrigger>
              <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                  <Condition Value="True">
                    <Condition.Binding>
                      <MultiBinding Converter="{StaticResource EqualityConverter}">
                        <Binding />
                        <Binding Path="DataContext.SelectedDocument.BoardDropTargetElement" RelativeSource="{RelativeSource AncestorType=Window}" />
                      </MultiBinding>
                    </Condition.Binding>
                  </Condition>
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource ControlAccent}" />
                <Setter Property="Opacity" Value="0.25" />
              </MultiDataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
